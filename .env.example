# Telegram Bot token from @BotFather
BOT_TOKEN=

# 3x-ui panel base URL including custom path (no trailing slash)
# Example: http://your-vps:54321/your-secret-path
XUI_BASE_URL=

# 3x-ui admin credentials
XUI_USERNAME=
XUI_PASSWORD=

# ID of the VLESS inbound to add clients to
XUI_INBOUND_ID=1

# Public VPS IP or hostname that goes into the VLESS link
XUI_PUBLIC_HOST=

# Public port for the VLESS link
XUI_PUBLIC_PORT=443

# Node.js version (for Render)
NODE_VERSION=22.23.1

# HTTP port for Render health check (Render sets this automatically)
PORT=3000
